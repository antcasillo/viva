# Configurazione nginx per viva.push.it (sito statico React/Vite)
# Copia in: /etc/nginx/sites-available/viva.push.it
# Poi: sudo ln -s /etc/nginx/sites-available/viva.push.it /etc/nginx/sites-enabled/
#      sudo nginx -t && sudo systemctl reload nginx
#
# SSL: adatta i path dei certificati se usi Let's Encrypt (certbot)

# Redirect HTTP -> HTTPS
server {
    listen 80;
    server_name viva.push.it;
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name viva.push.it;

    ssl_certificate     /etc/letsencrypt/live/viva.push.it/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/viva.push.it/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;

    access_log /var/log/nginx/viva.push.it.access.log;
    error_log  /var/log/nginx/viva.push.it.error.log;

    root /var/www/viva.push.it/viva-push-it/dist;
    index index.html;

    # SPA: tutte le route vanno a index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Cache per asset statici
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}
